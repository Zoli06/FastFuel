#!/bin/sh

FAILED=0
TMP_DIR="$(mktemp -d)"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔍 PRE-COMMIT QUALITY CHECKS"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# ──────────────
# Detect staged files
# ──────────────

STAGED_FILES=$(git diff --cached --name-only)

AFFECTS_BACKEND=0
AFFECTS_FRONTEND=0

echo "$STAGED_FILES" | grep -q "^server/FastFuel/" && AFFECTS_BACKEND=1
echo "$STAGED_FILES" | grep -q "^client/fast-fuel/" && AFFECTS_FRONTEND=1

if [ "$AFFECTS_BACKEND" -eq 0 ] && [ "$AFFECTS_FRONTEND" -eq 0 ]; then
  echo "ℹ️  No relevant staged files detected. Skipping checks."
  rm -rf "$TMP_DIR"
  exit 0
fi

run_check() {
  IDX="$1"
  NAME="$2"
  DIR="$3"
  CMD="$4"
  FIX_CMD="$5"

  OUT="$TMP_DIR/out_$IDX"
  STATUS="$TMP_DIR/status_$IDX"
  NAME_F="$TMP_DIR/name_$IDX"
  DIR_F="$TMP_DIR/dir_$IDX"
  FIX_F="$TMP_DIR/fix_$IDX"

  printf "%s" "$NAME" >"$NAME_F"
  printf "%s" "$DIR" >"$DIR_F"
  printf "%s" "$FIX_CMD" >"$FIX_F"

  (
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📁 Checking folder: $DIR for: $NAME"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    cd "$DIR" || exit 1
    sh -c "$CMD"
  ) >"$OUT" 2>&1

  echo $? >"$STATUS"
}

# ──────────────
# Schedule checks
# ──────────────

i=0

if [ "$AFFECTS_BACKEND" -eq 1 ]; then
  run_check $i "Backend compiler errors and warnings" "server/FastFuel" \
    "dotnet build -warnaserror" \
    "" &
  i=$((i+1))

  run_check $i "Backend code formatting" "server/FastFuel" \
    "dotnet format --verify-no-changes" \
    "dotnet format" &
  i=$((i+1))
fi

if [ "$AFFECTS_FRONTEND" -eq 1 ]; then
  run_check $i "Frontend linter errors and warnings" "client/fast-fuel" \
    "npm run lint" \
    "npm run lint -- --fix" &
  i=$((i+1))

  run_check $i "Frontend code formatting" "client/fast-fuel" \
    "npm run format:check" \
    "npm run format" &
  i=$((i+1))

  run_check $i "Frontend type errors" "client/fast-fuel" \
    "npm run test:ts" \
    "" &
  i=$((i+1))
fi

# ──────────────
# Wait for all
# ──────────────
wait

# ──────────────
# Print results
# ──────────────

i=0
while [ -f "$TMP_DIR/status_$i" ]; do
  STATUS="$(cat "$TMP_DIR/status_$i")"
  NAME="$(cat "$TMP_DIR/name_$i")"
  DIR="$(cat "$TMP_DIR/dir_$i")"
  FIX_CMD="$(cat "$TMP_DIR/fix_$i")"

  cat "$TMP_DIR/out_$i"

  if [ "$STATUS" -ne 0 ]; then
    FAILED=1
    echo ""
    echo "❌ Check FAILED in: $DIR"
    echo ""

    if [ -n "$FIX_CMD" ]; then
      echo "Fix it by running:"
      echo "  cd $DIR"
      echo "  $FIX_CMD"
    else
      echo "ℹ️  No automatic fix command provided."
    fi

    echo ""
  else
    echo ""
    echo "✅ Check passed: $DIR"
    echo ""
  fi

  i=$((i+1))
done

rm -rf "$TMP_DIR"

# ──────────────
# Final result
# ──────────────

if [ $FAILED -ne 0 ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "❌ COMMIT BLOCKED"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "One or more checks failed."
  echo ""
  echo "Fix the issues using the commands above,"
  echo "then commit again."
  echo ""
  echo "⚠️  Bypass (NOT recommended):"
  echo "   git commit --no-verify"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  exit 1
fi

echo ""
echo "✅ All checks passed"
exit 0
